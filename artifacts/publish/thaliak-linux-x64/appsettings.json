{
  "Directories": {
    "Boot": "./data/boot",
    "Patches": "./data/patches"
  },
  "Polling": {
    "DisableKoreaChecks": false,
    "DailyCheckTimePacific": "09:00",
    "MaintenanceActivePollMinutes": 2,
    "TraditionalChineseMaintenancePollMinutes": 30
  },
  "Notifications": {
    "QuietWindowMinutes": 3,
    "NotifyScrapedPatches": false,
    "SuppressBootPatchAlerts": true
  },
  "Webhooks": {
    "JsonEndpoints": []
  },
  "ConnectionStrings": {
    "sqlite": "Data Source=/data/thaliak.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
